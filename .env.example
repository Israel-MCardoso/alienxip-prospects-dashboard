GOOGLE_SHEET_CSV_URL=https://docs.google.com/spreadsheets/d/YOUR_SHEET_ID/gviz/tq?tqx=out:csv&gid=0
PORT=3000

# Supabase public values used by the Next.js app.
NEXT_PUBLIC_SITE_URL=https://your-motherxip-service.up.railway.app
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Local/server-only key for scripts such as npm run import:prospects.
# Never expose this value in frontend code and never commit .env.local.
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# n8n Outreach Automação (Sprint 16)
N8N_OUTREACH_WEBHOOK_URL=http://localhost:5678/webhook/motherxip-outreach-sandbox
MOTHERXIP_WEBHOOK_SECRET=change-me-sandbox-secret
MOTHERXIP_PUBLIC_URL=https://your-motherxip-service.up.railway.app

# SDR LLM Sandbox
SDR_LLM_MODE=mock

# ALIENXIP AI BRAIN future provider flags
# Keep disabled until a separate approval enables real provider calls.
PROVIDER_ENABLED=false
AI_DRY_RUN=true
OPENAI_API_KEY=
OPENAI_SDR_MODEL=gpt-4.1-mini
MAX_COST_PER_CONVERSATION=0
MAX_DAILY_COST=0
