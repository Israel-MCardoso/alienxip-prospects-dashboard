{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://alienxip.local/schemas/ai/MeetingDecision.schema.json",
  "title": "MeetingDecision",
  "type": "object",
  "additionalProperties": false,
  "required": ["should_schedule", "reason", "confidence", "handoff_required", "blocked_by"],
  "properties": {
    "should_schedule": { "type": "boolean" },
    "reason": { "type": "string" },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "suggested_meeting_title": { "type": "string" },
    "handoff_required": { "type": "boolean" },
    "blocked_by": { "type": "array", "items": { "type": "string" } }
  }
}
